OPENAI_API_KEY=
OPENAI_BASE_URL=
# 推荐填写 base URL，例如 https://api-inference.modelscope.cn/v1
# 若填写了完整 /chat/completions endpoint，客户端也会自动兼容。
MODELSCOPE_API_KEY=
MODELSCOPE_API_URL=
MODELSCOPE_MODEL=
# 推荐填写 base URL，例如 https://api-inference.modelscope.cn/v1
# 若填写了完整 /chat/completions endpoint，客户端也会自动兼容。
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen3.5-35b-instruct
# 与 ModelScope 并存时，若要让翻译主链走本机 OpenAI 兼容端点（如 llama.cpp），设 LLM_PREFER_OPENAI_COMPAT=1 并配置 OPENAI_BASE_URL + OPENAI_API_KEY
# LLM_PREFER_OPENAI_COMPAT=1
# OPENAI_BASE_URL=http://127.0.0.1:8001/v1
# OPENAI_API_KEY=
# 冒烟脚本：npm run translate:smoke -- data/test02/M422123.pdf --max-segments 40
# PDF 页栅格化（poppler pdftoppm）：默认长边 2048；本地多模态显式开启时用 VISION_LOCAL_MAX_RENDER_SIZE
# VISION_MAX_RENDER_SIZE=2048
# LOCAL_MULTIMODAL_RUNTIME=1
# VISION_USE_LOCAL_RENDER_SIZE=1
# VISION_LOCAL_MAX_RENDER_SIZE=1024
# VISION_MULTIMODAL_ENABLED=1
# VISION_MULTIMODAL_MAX_PAGES=2
# VISION_MODEL_API_TIMEOUT_MS=120000
# PDFTOPPM_BIN=pdftoppm
NEXT_PUBLIC_APP_NAME=Wish Export Agent
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BOT_WEBHOOK_URL=
FEISHU_BOT_SIGN_SECRET=
