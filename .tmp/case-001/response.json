                  {
                    "source": "Filled piping in contrast colour",
                    "translation": "撞色夹牙滚边。"
                  },
                  {
                    "source": "Double layer shell pocket, folded and glued top",
                    "translation": "双层面料口袋，口袋顶端折叠并做贴合处理。"
                  },
                  {
                    "source": "New inner shorts, see next page for details",
                    "translation": "新增内置短裤，详见下一页。"
                  },
                  {
                    "source": "Rubber logo glued to fabric, 18x15 mm wide, upraised print. 3 cm from hem, 1.5 cm from piping.",
                    "translation": "另一处硅胶 Logo，尺寸 18x15mm，距下摆 3cm，距夹牙滚边 1.5cm。"
                  },
                  {
                    "source": "Glued hem, slight shaped front and back",
                    "translation": "贴合下摆，前后幅做轻微造型。"
                  }
                ]
              },
              {
                "id": "inner-shorts",
                "title": "Inner Shorts / 内置短裤",
                "summary": "重点关注短裤的隐形效果、防滑功能和口袋设计。",
                "segments": [
                  {
                    "source": "Logo rubber print inside leg as grip function to prevent shorts from moving upwards",
                    "translation": "裤腿内侧增加硅胶 Logo 防滑带，用于防止短裤上移。"
                  },
                  {
                    "source": "Slanting side pocket, glued hem for flat appearance",
                    "translation": "侧边斜插袋，口袋边缘采用贴合工艺，保证外观平整。"
                  },
                  {
                    "source": "New inner shorts for least visible appearance",
                    "translation": "新版内置短裤，目标是尽量降低外观显露感。"
                  },
                  {
                    "source": "No CF seam",
                    "translation": "去除前中缝。"
                  },
                  {
                    "source": "Glued hems or similar flat and clean making",
                    "translation": "裤腿边缘采用无缝贴合或类似的平整工艺。"
                  },
                  {
                    "source": "Slanting pocket at right-hand side",
                    "translation": "右侧设斜插袋。"
                  }
                ]
              },
              {
                "id": "details-option-2",
                "title": "Details OP2 / 细节方案二",
                "summary": "方案二在方案一基础上增加开衩与不同滚边处理。",
                "segments": [
                  {
                    "source": "Please send 2 samples, one with slit (opt 2) and one with piping (opt 1)",
                    "translation": "请提供两件样品：一件做开衩（方案二），一件做夹牙滚边（方案一）。"
                  },
                  {
                    "source": "Rubber logo glued to fabric, 53x13 mm wide, upraised print. Centered, 2 cm from waist.",
                    "translation": "后腰下方居中位置放置 53x13mm 硅胶 Logo，距腰顶 2cm。"
                  },
                  {
                    "source": "Seam stitched and turned",
                    "translation": "缝线结构改为车缝后翻处理。"
                  },
                  {
                    "source": "Double layer shell pocket, folded and glued top",
                    "translation": "双层面料口袋，口袋顶端做贴合工艺。"
                  },
                  {
                    "source": "Slit at seam, 8 cm high",
                    "translation": "侧缝位置开衩，高度 8cm。"
                  },
                  {
                    "source": "Glued hem, slight shaped front and back",
                    "translation": "下摆贴合处理，前后幅略微塑形。"
                  }
                ]
              },
              {
                "id": "references-and-colours",
                "title": "References & Colours / 参考图与配色",
                "summary": "用于打样时快速回查结构参考和颜色定义。",
                "segments": [
                  {
                    "source": "Reference: open pocket CB",
                    "translation": "参考图：后中腰顶口袋。"
                  },
                  {
                    "source": "Reference: Rubber logo print inside leg",
                    "translation": "参考图：裤腿内侧 Logo 防滑带。"
                  },
                  {
                    "source": "Body: Navy",
                    "translation": "大身面料：藏青色。"
                  },
                  {
                    "source": "Inner shorts: DTM",
                    "translation": "内置短裤：顺大身面料色。"
                  },
                  {
                    "source": "Thread: DTM",
                    "translation": "缝纫线：顺大身面料色。"
                  },
                  {
                    "source": "Piping: White",
                    "translation": "滚边：白色。"
                  },
                  {
                    "source": "Bird: White",
                    "translation": "飞鸟图案：白色。"
                  },
                  {
                    "source": "Macade logo: White",
                    "translation": "Macade 品牌标识：白色。"
                  }
                ]
              }
            ]
          }
