{
  "schema_version": "1.1",
  "project_id": "export-agent-v1",
  "project_type": "private_ai_workspace",
  "description": "An internal, private-deployed AI workspace for foreign trade. Not a general chatbot.",
  "core_principles": {
    "skill_execution": "skill_catalog_plus_manual_composition",
    "automation_level": "human_in_the_loop_mandatory",
    "business_commitment": "explicit_confirmation_required"
  },
  "scope_v1": {
    "supported_roles": [
      "sales_rep",
      "sales_manager"
    ],
    "primary_interface": "web_workspace",
    "active_skills": [
      "bom_organization",
      "feedback_translation_and_consolidation",
      "customer_reply_drafting"
    ]
  },
  "strict_prohibitions": [
    "NO_automatic_continuous_execution_without_confirmation",
    "NO_auto_quoting",
    "NO_auto_sending_external_messages",
    "NO_auto_writing_to_erp_or_crm"
  ],
  "human_confirmation_rules": {
    "must_flag_as_pending_confirmation": [
      "price",
      "delivery_date",
      "certification",
      "payment_terms",
      "logistics"
    ],
    "review_process": "crucial_steps_require_manual_review_before_proceeding"
  },
  "memory_files_priority": [
    {
      "file": "./manifest.json",
      "description": "Global context, boundaries, and strict prohibitions."
    },
    {
      "file": "./execution-boundaries.md",
      "description": "Detailed rules on what the system can/cannot do automatically and role permissions."
    },
    {
      "file": "./acceptance-criteria.md",
      "description": "Engineering and product acceptance baselines for UI and workflows."
    },
    {
      "file": "./ting-runtime-memory.md",
      "description": "Runtime memory card for Ting routing/disambiguation responsibility and user-facing language constraints."
    },
    {
      "file": "./adai-runtime-memory.md",
      "description": "Runtime memory card for ADai triage boundaries and root-cause split between Ting protocol vs export-agent execution."
    }
  ]
}