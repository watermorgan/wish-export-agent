{
  "$comment": "PDF 标注布局策略参数。被 render_feedback_pdf.py 和 translation-pipeline.ts 消费。通过 scripts/calibrate-layout-params.ts 校准。",
  "version": "0.1.0",
  "updatedAt": "2026-04-15",

  "global": {
    "densePageNoteThreshold": 18,
    "crowdedThreshold": 14,
    "inlineNoteMaxZhLen": 30,
    "inlineNoteCombinedMaxLen": 160,
    "inlineNoteMaxWidth": 188,
    "inlineNoteMinWidth": 76,
    "inlineNoteMaxShift": 120,
    "inlineNoteScanStep": 12,
    "inlineNoteWideSourceThreshold": 150,
    "inlineNoteTallSourceThreshold": 48,
    "inlineNoteSketchMaxWidth": 124,
    "inlineNoteSketchMinWidth": 64,
    "markerFontSize": 10,
    "panelWidth": 340,
    "pagePadding": 18,
    "boxPadding": 10,
    "boxGap": 10,
    "columnGap": 8,
    "denseRowTolerance": 8.0,
    "denseRowMaxItems": 3,
    "denseRowMaxSourceChars": 100,
    "smartPlacementEnabled": true,
    "tableCommentHeaders": ["comment", "notes", "备注", "说明", "description"],
    "inlineMinFreeSpace": 20,
    "inlineFontBySpace": {"60": 7.0, "40": 6.0, "20": 5.0},
    "inlineMaxVerticalShift": 24,
    "bottomZoneMinHeight": 50,
    "bottomZoneFontSize": 7.0,
    "bottomZoneColumns": 2,
    "collisionPadding": 1
  },

  "levelDecision": {
    "$comment": "分层决策：Level1=近场旁注, Level2=右侧说明栏, Level3=补充review页",
    "bboxDensityThreshold": 0.35,
    "minFreeSpaceRatio": 0.15,
    "overlapSafetyMargin": 4
  },

  "byDocumentType": {
    "sketch_comment": {
      "nearFieldThreshold": 30,
      "densePageNoteThreshold": 25,
      "crowdedThreshold": 20,
      "inlineNoteMaxWidth": 124,
      "inlineNoteMinWidth": 64,
      "$comment": "sketch 页通常空白较多，可容纳更多近场旁注。sketch_comment 在 TS 侧当前默认不走 inline（全部 footnote），未来放开时使用这些参数。"
    },
    "mixed": {
      "nearFieldThreshold": 20,
      "densePageNoteThreshold": 18,
      "crowdedThreshold": 14,
      "$comment": "mixed 页布局变化大，保守处理"
    },
    "tp_bom_table_heavy": {
      "nearFieldThreshold": 12,
      "densePageNoteThreshold": 10,
      "crowdedThreshold": 8,
      "$comment": "表格密集页，空白极少，快速降级到 dense/review"
    }
  },

  "pageRenderDecision": {
    "$comment": "Page-level unified render mode: 同一页统一使用 inline 或 panel，不再逐条混排。",
    "pageInlineMaxNotes": 8,
    "pageInlineMaxTotalChars": 200,
    "pageInlineMaxSingleChars": 40,
    "notes": "翻译条目数 > pageInlineMaxNotes 或总字符数 > pageInlineMaxTotalChars 或单条 > pageInlineMaxSingleChars → 整页走 panel 模式；否则走 inline 模式。用户可通过 override 强制指定。"
  },

  "calibration": {
    "$comment": "校准元数据 - 记录参数是如何确定的",
    "method": "manual_initial",
    "basedOnSamples": ["M422123", "M445033", "M415013", "M441083"],
    "lastCalibratedAt": "2026-04-15",
    "notes": "初始参数基于 acceptance-criteria.md 和现有硬编码值。待 scripts/calibrate-layout-params.ts 实现后用样本数据校准。"
  }
}
